{
    "manifest_version": 3,
    "name": "PAM cart checker",
    "description": "Never forget essential items when shopping at online supermarkets. Create a list of indispensable products, and the extension will alert you if any items are missing.",
    "version": "0.3.0",
    "action": {
        "default_popup": "./popup/popup.html",
        "default_icon": "./images/foobar.png"
    },
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "content_scripts": [
        {
            "js": [
                "public/content.js"
            ],
            "matches": [
                "https://pamacasa.pampanorama.it/*"
            ]
        }
    ]
}
